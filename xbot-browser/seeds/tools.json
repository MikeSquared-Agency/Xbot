{
  "version": 1,
  "domains": [
    {
      "domain": "x.com",
      "urlPattern": "/*",
      "title": "x.com",
      "description": "X (Twitter) — social media platform"
    },
    {
      "domain": "accounts.google.com",
      "urlPattern": "/*",
      "title": "accounts.google.com",
      "description": "Google account sign-in"
    },
    {
      "domain": "claude.ai",
      "urlPattern": "/*",
      "title": "claude.ai",
      "description": "Anthropic Claude AI assistant"
    }
  ],
  "tools": [
    {
      "domain": "x.com",
      "name": "x:check-session",
      "description": "Check if the current browser session is authenticated on X (Twitter). Navigates to x.com/home and detects whether the user is logged in or redirected to a login page. Returns { authenticated, url, title }.",
      "inputSchema": [],
      "execution": {
        "type": "workflow",
        "steps": [
          { "action": "navigate", "url": "https://x.com/home" },
          {
            "action": "checkUrl",
            "patterns": ["/login", "/i/flow/login", "/account/access"],
            "titlePatterns": ["log in"],
            "resultField": "isLoginPage"
          },
          {
            "action": "return",
            "value": { "authenticated": "!isLoginPage", "url": "$url", "title": "$title" }
          }
        ]
      }
    },
    {
      "domain": "x.com",
      "name": "x:pull-analytics",
      "description": "Navigate to X Analytics content tab, trigger CSV export, and return the raw CSV text. The CSV contains per-post metrics: impressions, likes, retweets, replies, engagements. Requires an authenticated X session.",
      "inputSchema": [
        { "name": "days", "type": "number", "description": "Number of days of analytics to export", "required": false, "default": 1 }
      ],
      "execution": {
        "type": "workflow",
        "steps": [
          {
            "action": "navigate",
            "urlTemplate": "https://x.com/i/account_analytics/content?type=all&sort=impressions&dir=desc&from={from}&to={to}",
            "computeParams": {
              "from": { "type": "dateOffset", "field": "days", "default": 1, "format": "YYYY-MM-DD" },
              "to": { "type": "today", "format": "YYYY-MM-DD" }
            }
          },
          { "action": "waitForLoadState", "state": "networkidle", "timeout": 15000 },
          {
            "action": "download",
            "selector": "button:has(svg[data-icon=\"icon-incoming\"])",
            "fallbackSelectors": [
              "button:has(svg path[d^=\"M11.99 16\"])",
              "[aria-label*=\"download\" i]",
              "[aria-label*=\"export\" i]",
              "[data-testid*=\"download\"]",
              "[data-testid*=\"export\"]",
              "button:has-text(\"Export\")",
              "button:has-text(\"Download\")"
            ],
            "returnContent": true
          }
        ]
      }
    },
    {
      "domain": "x.com",
      "name": "x:get-home-feed",
      "description": "Scroll the X home feed (For you tab) and extract visible tweet cards with their URLs. Returns an array of { text, url } objects. Uses the algorithmic For you feed which surfaces trending and relevant content. Requires an authenticated X session.",
      "inputSchema": [],
      "execution": {
        "type": "workflow",
        "steps": [
          { "action": "navigate", "url": "https://x.com/home" },
          { "action": "waitForLoadState", "state": "networkidle", "timeout": 15000 },
          { "action": "wait", "selector": "article[data-testid=\"tweet\"]", "timeout": 10000 },
          { "action": "scroll", "distance": 1000, "count": 5, "delay": 1500, "waitForLoadState": "networkidle", "timeout": 10000 },
          {
            "action": "extract",
            "selector": "article[data-testid=\"tweet\"]",
            "extractMode": "recordList",
            "fields": [
              { "name": "text", "extract": "innerText" },
              { "name": "url", "subSelector": "a:has(time)", "extract": "attribute", "attribute": "href" }
            ]
          }
        ]
      }
    },
    {
      "domain": "x.com",
      "name": "x:get-list-feed",
      "description": "Navigate to an X list and extract visible tweet cards with their URLs. Returns an array of { text, url } objects for each tweet. Requires an authenticated X session.",
      "inputSchema": [
        { "name": "list_url", "type": "string", "description": "Full URL of the X list (e.g. https://x.com/i/lists/123)", "required": true }
      ],
      "execution": {
        "type": "workflow",
        "steps": [
          { "action": "navigate", "url": "{list_url}" },
          { "action": "waitForLoadState", "state": "networkidle", "timeout": 15000 },
          { "action": "wait", "selector": "article[data-testid=\"tweet\"]", "timeout": 10000 },
          { "action": "scroll", "distance": 1000, "count": 3, "delay": 1500, "waitForLoadState": "networkidle", "timeout": 10000 },
          {
            "action": "extract",
            "selector": "article[data-testid=\"tweet\"]",
            "extractMode": "recordList",
            "fields": [
              { "name": "text", "extract": "innerText" },
              { "name": "url", "subSelector": "a:has(time)", "extract": "attribute", "attribute": "href" }
            ]
          }
        ]
      }
    },
    {
      "domain": "x.com",
      "name": "x:search-tweets",
      "description": "Search X for tweets matching a query. Returns an array of { text, url } objects for each tweet. Requires an authenticated X session.",
      "inputSchema": [
        { "name": "query", "type": "string", "description": "Search query string", "required": true },
        { "name": "tab", "type": "string", "description": "Search tab: live (latest) or top", "required": false, "default": "live" }
      ],
      "execution": {
        "type": "workflow",
        "steps": [
          { "action": "navigate", "urlTemplate": "https://x.com/search?q={query}&src=typed_query&f={tab}" },
          { "action": "waitForLoadState", "state": "networkidle", "timeout": 15000 },
          { "action": "wait", "selector": "article[data-testid=\"tweet\"]", "timeout": 10000 },
          {
            "action": "extract",
            "selector": "article[data-testid=\"tweet\"]",
            "extractMode": "recordList",
            "fields": [
              { "name": "text", "extract": "innerText" },
              { "name": "url", "subSelector": "a:has(time)", "extract": "attribute", "attribute": "href" }
            ]
          }
        ]
      }
    },
    {
      "domain": "x.com",
      "name": "x:get-author-profile",
      "description": "Navigate to an X user's profile and extract structured profile data: display name, handle, bio, location, website, join date, follower/following counts. Requires an authenticated X session.",
      "inputSchema": [
        { "name": "handle", "type": "string", "description": "X handle without @ (e.g. Hesamation)", "required": true }
      ],
      "execution": {
        "type": "workflow",
        "steps": [
          { "action": "navigate", "urlTemplate": "https://x.com/{handle}" },
          { "action": "waitForLoadState", "state": "networkidle", "timeout": 15000 },
          { "action": "wait", "selector": "[data-testid=\"UserName\"]", "timeout": 10000 },
          { "action": "extract", "selector": "[data-testid=\"UserName\"]", "extractMode": "innerText", "into": "userName" },
          { "action": "extract", "selector": "[data-testid=\"UserDescription\"]", "extractMode": "innerText", "into": "bio" },
          { "action": "extract", "selector": "[data-testid=\"UserProfileHeader_Items\"]", "extractMode": "innerText", "into": "headerItems" },
          { "action": "extract", "selector": "a[href$=\"/verified_followers\"]", "extractMode": "innerText", "into": "followers" },
          { "action": "extract", "selector": "a[href$=\"/following\"]", "extractMode": "innerText", "into": "following" },
          {
            "action": "return",
            "value": {
              "userName": "userName",
              "bio": "bio",
              "headerItems": "headerItems",
              "followers": "followers",
              "following": "following",
              "url": "$url"
            }
          }
        ]
      }
    },
    {
      "domain": "x.com",
      "name": "x:get-author-timeline",
      "description": "Navigate to an X user's profile and extract their recent tweets. Scrolls down to load more tweets beyond the pinned/first few. Returns the innerText of each tweet article element. The agent parses author, content, and metrics itself. Requires an authenticated X session.",
      "inputSchema": [
        { "name": "handle", "type": "string", "description": "X handle without @ (e.g. Hesamation)", "required": true },
        { "name": "count", "type": "number", "description": "Approximate number of tweets to fetch (controls scroll count)", "required": false, "default": 10 }
      ],
      "execution": {
        "type": "workflow",
        "steps": [
          { "action": "navigate", "urlTemplate": "https://x.com/{handle}" },
          { "action": "waitForLoadState", "state": "networkidle", "timeout": 15000 },
          { "action": "wait", "selector": "article[data-testid=\"tweet\"]", "timeout": 10000 },
          { "action": "scroll", "distance": 1000, "count": 3, "delay": 1500, "waitForLoadState": "networkidle", "timeout": 10000 },
          { "action": "extract", "selector": "article[data-testid=\"tweet\"]", "extractMode": "innerTextList" }
        ]
      }
    },
    {
      "domain": "x.com",
      "name": "x:post-reply",
      "description": "Post a reply to a specific tweet. Navigates to the tweet, clicks the reply compose area, types the reply text, and clicks Reply. Returns success status. Requires an authenticated X session. IMPORTANT: Use sparingly — rate limits apply.",
      "inputSchema": [
        { "name": "tweet_url", "type": "string", "description": "Full URL of the tweet to reply to", "required": true },
        { "name": "reply_text", "type": "string", "description": "The reply text (max 280 chars)", "required": true }
      ],
      "execution": {
        "type": "workflow",
        "steps": [
          { "action": "navigate", "url": "{tweet_url}" },
          { "action": "waitForLoadState", "state": "networkidle", "timeout": 15000 },
          {
            "action": "wait",
            "selector": "div[data-testid=\"tweetTextarea_0\"]",
            "timeout": 10000
          },
          {
            "action": "click",
            "selector": "div[data-testid=\"tweetTextarea_0\"]",
            "fallbackSelectors": [
              "div[data-testid=\"tweetTextarea_0RichTextInputContainer\"]",
              "div[role=\"textbox\"][data-testid=\"tweetTextarea_0\"]",
              "[aria-label=\"Post text\"]",
              "[aria-label=\"Post your reply\"]"
            ]
          },
          { "action": "fill", "selector": "div[data-testid=\"tweetTextarea_0\"]", "param": "reply_text" },
          {
            "action": "click",
            "selector": "[data-testid=\"tweetButtonInline\"]",
            "fallbackSelectors": [
              "[data-testid=\"tweetButton\"]",
              "button[data-testid*=\"Reply\"]",
              "div[role=\"button\"][data-testid*=\"tweet\"]"
            ]
          },
          { "action": "waitForLoadState", "state": "networkidle", "timeout": 10000 },
          { "action": "return", "value": { "success": true, "url": "$url" } }
        ]
      }
    },
    {
      "domain": "accounts.google.com",
      "name": "google-enter-email",
      "description": "Enter an email address on the Google sign-in page and click Next",
      "inputSchema": [
        { "name": "email", "type": "string", "description": "Email address to enter", "required": true }
      ],
      "execution": {
        "fields": [
          { "selector": "input[type=\"email\"]", "param": "email" }
        ],
        "submit": { "selector": "#identifierNext button" },
        "waitFor": "input[type=\"password\"], #identifierNext"
      }
    },
    {
      "domain": "accounts.google.com",
      "name": "google-enter-password",
      "description": "Enter a password on the Google sign-in page and click Next",
      "inputSchema": [
        { "name": "password", "type": "string", "description": "Password to enter", "required": true }
      ],
      "execution": {
        "fields": [
          { "selector": "input[type=\"password\"]", "param": "password" }
        ],
        "submit": { "selector": "#passwordNext button" }
      }
    },
    {
      "domain": "claude.ai",
      "name": "claude-dismiss-cookies",
      "description": "Dismiss the cookie consent banner on claude.ai",
      "inputSchema": [],
      "execution": {
        "type": "workflow",
        "steps": [
          {
            "action": "click",
            "selector": "button:has-text(\"Dismiss\")",
            "fallbackSelectors": [
              "button:has-text(\"Accept\")",
              "button:has-text(\"Got it\")",
              "[data-testid=\"cookie-banner-dismiss\"]"
            ]
          }
        ]
      }
    },
    {
      "domain": "claude.ai",
      "name": "claude-click-google-login",
      "description": "Click the 'Continue with Google' button on the claude.ai login page",
      "inputSchema": [],
      "execution": {
        "type": "workflow",
        "steps": [
          {
            "action": "click",
            "selector": "button:has-text(\"Continue with Google\")",
            "fallbackSelectors": [
              "[data-testid=\"google-login\"]",
              "a:has-text(\"Google\")",
              "button:has-text(\"Google\")"
            ]
          }
        ]
      }
    }
  ]
}
